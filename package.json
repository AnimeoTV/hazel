{
  "name": "hazel-server",
  "version": "5.1.2",
  "main": "lib/index.js",
  "description": "Lightweight update server for Electron apps",
  "scripts": {
    "start": "dotenv node .",
    "prettier": "prettier --single-quote --no-semi --write --no-editorconfig \"**/*\".js",
    "test": "xo && dotenv jest"
  },
  "license": "MIT",
  "repository": "AnimeoTV/hazel",
  "xo": {
    "extends": [
      "prettier"
    ],
    "rules": {
      "camelcase": 0,
      "new-cap": 0,
      "unicorn/no-process-exit": 0,
      "no-await-in-loop": 0,
      "unicorn/import-index": 0
    }
  },
  "lint-staged": {
    "*.js": [
      "prettier --single-quote --no-semi --write --no-editorconfig",
      "npm test && :",
      "git add"
    ]
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "date-fns": "4.3.0",
    "dotenv-cli": "11.0.0",
    "express": "5.2.1",
    "express-useragent": "2.2.0",
    "finalhandler": "2.1.1",
    "handlebars": "4.7.9",
    "http-proxy": "^1.18.1",
    "jest": "30.4.2",
    "just-handlebars-helpers": "^1.0.19",
    "ms": "2.1.3",
    "node-fetch": "2.7.0",
    "router": "2.2.0",
    "semver": "7.8.1",
    "stream-to-string": "1.2.1",
    "test-listen": "1.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "xo": "2.0.2"
  }
}
